# Veridian AI - Configuration Example
# Renommez ce fichier en .env et remplissez les valeurs.

# Discord
DISCORD_TOKEN=votre_token_bot
DISCORD_CLIENT_ID=id_client_oauth2
DISCORD_CLIENT_SECRET=secret_client_oauth2
BOT_OWNER_DISCORD_ID=1047760053509312642

# Base de données (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=votre_password
DB_NAME=veridian

# IA (Groq)
# Jusqu'à 4 clés pour le fallback automatique
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...
GROQ_API_KEY_4=gsk_...

# API & Dashboard
ENVIRONMENT=development
API_PORT=8000
API_DOMAIN=api.veridiancloud.xyz
DASHBOARD_URL=https://veridiancloud.xyz/dashboard
# Secrets de sécurité (seront générés automatiquement en dev si vides)
# En production, utilisez des chaînes fortes (32+ caractères).
INTERNAL_API_SECRET=change_me_in_production_min_32_chars
JWT_SECRET=change_me_in_production_min_32_chars

# Paiements
OXAPAY_MERCHANT_KEY=votre_cle_oxapay
OXAPAY_WEBHOOK_SECRET=votre_secret_webhook
PAYPAL_EMAIL=votre_email_paypal
