    <mxCell id="tf11" value="11. Dashboard:&#xa;ticket fermé visible,&#xa;réouverture possible" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="zone_ticket_flow">
