      <mxGeometry x="290" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf4" value="4. Messages traduits&#xa;bidirectionnellement&#xa;(cache SHA256)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="430" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf5" value="5. Staff prend&#xa;le ticket (bouton)&#xa;Round-robin Pro" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="570" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf6" value="6. Priorisation IA&#xa;(low/medium/high/urgent)&#xa;SLA check 5min" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="710" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf7" value="7. /close ou bouton&#xa;→ pending_close&#xa;→ confirmation staff" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="850" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf8" value="8. Résumé IA généré&#xa;+ Transcript bilingue&#xa;+ DM utilisateur" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="990" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf9" value="9. Rating satisfaction&#xa;DM 1-5★&#xa;→ vai_ticket_satisfaction" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="1130" y="40" width="120" height="50" as="geometry" />
    </mxCell>
    <mxCell id="tf10" value="10. Channel supprimé&#xa;automatiquement&#xa;après 10s" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="1270" y="40" width="120" height="50" as="geometry" />
