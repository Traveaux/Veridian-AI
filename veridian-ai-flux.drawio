    <mxCell id="api_auth" value="🔐 /auth/* — OAuth2 Discord&#xa;• GET /auth/discord/login → redirect Discord&#xa;• GET /auth/callback → échange code&#xa;• POST /auth/exchange → temp_code → JWT&#xa;• GET /auth/user/me → profil utilisateur&#xa;• GET /auth/user/guilds → liste serveurs&#xa;• POST /auth/logout → révoque session&#xa;JWT stocké en localStorage (7j)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="zone_api">
      <mxGeometry x="10" y="40" width="300" height="110" as="geometry" />
    </mxCell>

    <mxCell id="api_internal" value="🔧 /internal/* — Dashboard ↔ Bot&#xa;• GET/PUT /guild/{id}/config&#xa;• GET /guild/{id}/tickets (paginé)&#xa;• GET /guild/{id}/stats&#xa;• POST /guild/{id}/purchase&#xa;• POST /ticket/{id}/close|reopen&#xa;• PUT /ticket/{id}/priority&#xa;• GET/POST /guild/{id}/kb&#xa;• POST /bot/heartbeat&#xa;• GET /bot/status&#xa;Auth: JWT Bearer ou X-API-SECRET" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="zone_api">
      <mxGeometry x="10" y="165" width="300" height="150" as="geometry" />
    </mxCell>

    <mxCell id="api_webhook" value="🪝 /webhook/oxapay — Paiement Crypto&#xa;• POST /webhook/oxapay&#xa;• Vérifie HMAC-SHA256&#xa;• Update vai_orders status→paid&#xa;• Crée vai_payments record&#xa;• Active vai_subscriptions&#xa;• Ajoute vai_pending_notifications&#xa;• Notifie Bot Owner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="zone_api">
      <mxGeometry x="10" y="330" width="300" height="110" as="geometry" />
    </mxCell>

    <mxCell id="api_dashboard" value="🛠 /dashboard/* — Super Admin&#xa;• GET /dashboard/orders/pending&#xa;• POST /dashboard/orders/{id}/validate&#xa;• POST /dashboard/orders/{id}/reject&#xa;• GET/POST /dashboard/subscriptions&#xa;• GET /dashboard/stats (global)&#xa;• GET/POST /dashboard/kb/{guild_id}&#xa;Auth: verify_super_admin() uniquement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="zone_api">
      <mxGeometry x="10" y="455" width="300" height="110" as="geometry" />
    </mxCell>

    <mxCell id="api_i18n" value="🌍 /i18n/* — Traductions web&#xa;• POST /i18n/translate (via API Grok xai-)&#xa;• GET /i18n/translations?lang=&amp;keys=&#xa;• POST /i18n/clear?lang=&#xa;• GET /i18n/stats&#xa;Stockage: vai_i18n_translations (MySQL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="zone_api">
      <mxGeometry x="10" y="580" width="300" height="80" as="geometry" />
    </mxCell>

    <mxCell id="api_middleware" value="🛡 Middlewares&#xa;• CORSMiddleware (veridiancloud.xyz)&#xa;• Rate Limiting in-memory (60 req/min)&#xa;• Security Headers (nosniff, no-store…)&#xa;• db_migrate auto au démarrage&#xa;• JWT verify + session DB revocation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;" vertex="1" parent="zone_api">
