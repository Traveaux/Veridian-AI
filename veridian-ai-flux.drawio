    <mxCell id="tf2" value="2. Channel créé&#xa;+ Embed bienvenue&#xa;+ Logs channel" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="150" y="40" width="120" height="50" as="geometry" />
