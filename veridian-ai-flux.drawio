    <mxCell id="tf1" value="1. /ticket&#xa;Utilisateur ouvre" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="zone_ticket_flow">
      <mxGeometry x="10" y="40" width="120" height="50" as="geometry" />
